import java.util.ArrayList;
import java.util.HashMap;
import java.util.Map;
import java.util.Random;

class RandomizedSet {

    private final ArrayList<Integer> list;
    private final Map<Integer, Integer> map;
    private final Random rand;

    public RandomizedSet() {
        list = new ArrayList<>();
        map = new HashMap<>();
        rand = new Random();
    }
    
    public boolean insert(int val) {
        if (map.containsKey(val)) {
            return false;
        }
        
        // Map the value to its incoming index in the list
        map.put(val, list.size());
        list.add(val);
        return true;
    }
    
    public boolean remove(int val) {
        if (!map.containsKey(val)) {
            return false;
        }
        
        // Get the index of the element to remove
        int idxToRemove = map.get(val);
        int lastElement = list.get(list.size() - 1);
        
        // Move the last element to the place of the element we want to delete
        list.set(idxToRemove, lastElement);
        map.put(lastElement, idxToRemove);
        
        // Remove the final element from both list and map
        list.remove(list.size() - 1);
        map.remove(val);
        
        return true;
    }
    
    public int getRandom() {
        // Pick a random index from the list
        int randomIdx = rand.nextInt(list.size());
        return list.get(randomIdx);
    }
}

