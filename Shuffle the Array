class Solution {
    public int[] shuffle(int[] nums, int n) {
        int[] result = new int[2 * n];
        int index = 0;

        // Alternate between x_i and y_i elements
        for (int i = 0; i < n; i++) {
            result[index++] = nums[i];     // Append x_i
            result[index++] = nums[i + n]; // Append y_i
        }

        return result;
    }
}
