import java.util.PriorityQueue;

class KthLargest {
    private final PriorityQueue<Integer> minHeap;
    private final int k;

    public KthLargest(int k, int[] nums) {
        this.k = k;
        this.minHeap = new PriorityQueue<>(k);
        
        // Add all initial numbers to the stream
        for (int num : nums) {
            add(num);
        }
    }
    
    public int add(int val) {
        // Add the new score to our min-heap
        minHeap.offer(val);
        
        // If the heap exceeds size k, evict the smallest element
        if (minHeap.size() > k) {
            minHeap.poll();
        }
        
        // The top of the min-heap is now the kth largest element
        return minHeap.peek();
    }
}

