class Codechef
{
	public static void main (String[] args) 
	{
         String sentence = "Coding on CodeChef";

        
        String[] words = sentence.split(" ");

        
        for (String word : words) {
            System.out.println(word + " - " + word.length());
        }

        
        System.out.println(sentence + " - " + sentence.length());
    }
}
