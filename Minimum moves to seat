#include <stdio.h>
#include <stdlib.h>
int compare(const void *a,const void *b){
    return (*(int*)a-*(int*)b);
}

int calculate_min_moves(int* seats, int* students, int n) {
    // Write your logic here.
    qsort(seats,n,sizeof(int),compare);
    qsort(students,n,sizeof(int),compare);
    int total_moves=0;
    for(int i=0;i<n;i++){
        total_moves+=abs(seats[i]-students[i]);
    }
    return total_moves;
}

int main() {
    int n;
    scanf("%d", &n);
    int* seats = (int*)malloc(n * sizeof(int));
    int* students = (int*)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) {
        scanf("%d", &seats[i]);
    }
    for (int i = 0; i < n; i++) {
        scanf("%d", &students[i]);
    }
    int result = calculate_min_moves(seats, students, n);
    printf("%d\n", result);
    free(seats);
    free(students);
    return 0;
}
