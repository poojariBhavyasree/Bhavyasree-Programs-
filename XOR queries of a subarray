#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    if(scanf("%d",&n)!=1)return 0;
    int* arr=(int*)malloc(n*sizeof(int));
    int* prefix=(int*)malloc((n+1)*sizeof(int));
    prefix[0]=0;
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
        prefix[i+1]=prefix[i]^arr[i];
    }
    int q;
    if(scanf("%d",&q)!=1){
        free(arr);
        free(prefix);
        return 0;
    }
    int cols;
    scanf("%d",&cols);
    for(int i=0;i<q;i++){
        int left,right;
        scanf("%d %d",&left,&right);
        int ans=prefix[right+1]^prefix[left];
        printf("%d\n",ans);
        if(i<q-1){
            printf(" ");
        }
    }
    printf("\n");
    free(arr);
    free(prefix);    
    return 0;
}
             
